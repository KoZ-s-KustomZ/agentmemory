{
  "mcpServers": {
    "agentmemory": {
      "command": "node",
      "args": ["$CLAUDE_PROJECT_DIR/dist/standalone.mjs"],
      "env": {
        "AGENTMEMORY_URL": "http://localhost:3111"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/dist/hooks/pre-tool-use.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/dist/hooks/post-tool-use.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/dist/hooks/stop.mjs"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/dist/hooks/notification.mjs"
          }
        ]
      }
    ]
  }
}
